# ============================================
# Wakaman — Variables d'environnement
# ============================================
# IMPORTANT : copier ce fichier en .env (non versionné)
# Ne jamais committer le .env avec les vraies valeurs

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://wakaman:wakaman_dev@localhost:5432/wakaman?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://wakaman:wakaman_dev@localhost:5672

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=wakaman_dev_key

# JWT
JWT_SECRET=change_me_in_production_at_least_32_characters_long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# MTN Mobile Money (sandbox)
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
MTN_MOMO_USER_ID=your_user_id
MTN_MOMO_ENV=sandbox  # sandbox | production
MTN_MOMO_CALLBACK_URL=https://api.wakaman.com/api/v1/payments/mtn-callback

# Orange Money (sandbox)
ORANGE_MONEY_CLIENT_ID=your_orange_client_id
ORANGE_MONEY_CLIENT_SECRET=your_orange_client_secret
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key
ORANGE_MONEY_ENV=sandbox
ORANGE_MONEY_CALLBACK_URL=https://api.wakaman.com/api/v1/payments/orange-callback

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

# Firebase (push notifications)
FIREBASE_PROJECT_ID=wakaman-prod
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-admin@wakaman.iam.gserviceaccount.com

# Mapbox
MAPBOX_ACCESS_TOKEN=your_mapbox_token

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Email (dev: Mailhog, prod: SendGrid)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@wakaman.com

# Storage (dev: local, prod: GCS)
STORAGE_PROVIDER=local
GCS_BUCKET_NAME=wakaman-uploads
GCS_PROJECT_ID=wakaman-prod
